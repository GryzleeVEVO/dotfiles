# i3wm config file

# The configuration is split into several files for simplicity
# This file contains shared variables and includes for the rest of the files
# and worspace configuration

# Modifier key (Mod4 = Windows/Command/Super, Mod1 = alt)
set $mod Mod4

# Workspace names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Config is split along several files for simplicity

# Non-essential programs to run at launch
include $HOME/.config/i3/run

# Theme and graphical settings
include $HOME/.config/i3/theme

# Navigation keybindings
include $HOME/.config/i3/binds

# Keybinds and options for programs
include $HOME/.config/i3/programs

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork --blur 5
