# i3wm config file

# This file contains keybindings and window associations for programs

# Command for automatically switching to correct workspace
set $switch_to_ws i3-msg workspace

# Program menu --> dmenu
bindsym $mod+d          exec --no-startup-id rofi -show drun -theme $HOME/.config/rofi/menu.rasi 
bindsym $mod+Shift+p    exec --no-startup-id $HOME/.config/rofi/./powermenu.sh


# Terminal --> Alacritty
bindsym $mod+Return     exec --no-startup-id i3-sensible-terminal
                        #exec --no-startup-id $switch_to_ws $ws1

#for_window [class="Alacritty"] move to workspace $ws1

# Browser --> Chrome
bindsym $mod+n          exec --no-startup-id google-chrome-stable
                        #exec --no-startup-id $switch_to_ws $ws2
bindsym $mod+Shift+n    exec --no-startup-id google-chrome-stable --incognito
                        #exec --no-startup-id $switch_to_ws $ws2

#for_window [class="Google-chrome"] move to workspace $ws2

# Editor --> VS Code
bindsym $mod+t          exec --no-startup-id code
                        #exec --no-startup-id $switch_to_ws $ws3

#for_window [class="Code"] move to workspace $ws3

