# i3wm config file

# This file contains keybindings and window associations for programs

bindsym $mod+d          exec --no-startup-id rofi -show drun -theme $HOME/.config/rofi/menu.rasi 
bindsym $mod+Shift+p    exec --no-startup-id $HOME/.config/rofi/./powermenu.sh

bindsym $mod+Return     exec --no-startup-id i3-sensible-terminal

bindsym $mod+n          exec --no-startup-id google-chrome-stable
bindsym $mod+Shift+n    exec --no-startup-id google-chrome-stable --incognito

bindsym $mod+m          exec --no-startup-id discord

bindsym $mod+Shift+t    exec --no-startup-id code
bindsym $mod+t          exec --no-startup-id i3-sensible-terminal -e nvim "$HOME"

bindsym $mod+r          exec --no-startup-id i3-sensible-terminal -e ranger 


for_window [class="Blueman-manager"] floating enable
for_window [class="pavucontrol"] floating enable

