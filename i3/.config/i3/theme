# i3wm config file

# This file contains graphical options for the window manager

# Font
set $userfont NotoSans Nerd Font, JetBrainsMono
font pango:$userfont 12

# Color
set $bg 	#1F2430
set $fg 	#FFFFFF
set $focus 	#8775B0
set $urgent    	#FFA759

# Class                 Border      Background  Text        Indices     Child border
client.unfocused        $bg 	$bg 	$fg 	$bg 	$bg
client.focused 		$focus 	$focus 	$fg 	$focus 	$focus
client.urgent           $urgent $urgent $fg 	$urgent $urgent

# Gaps and borders
gaps inner 10
gaps outer 10
smart_gaps on
smart_borders on
default_border pixel 1

# Bar
exec_always --no-startup-id "polybar-msg cmd quit ; polybar bottom"

# Wallpaper
exec_always --no-startup-id nitrogen --restore

# Composer
exec --no-startup-id picom
