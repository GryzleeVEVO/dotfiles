# Use Windows key as modifier
set $mod Mod4

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Look and feel
set $font_mono "pango:JetBrains Mono 10"
set $wallpaper "$HOME/Pictures/wallpapers/sebastian-svenson-d2w-_1LJioQ-unsplash.jpg"

set $bg_color #323232
set $bg_accent_color #076678
set $fg_color #ebdbb2
set $fg_inactive_color #5c5c5c

# Default programs
set $term alacritty
set $browser firefox
set $private-browser firefox --private-window
set $menu wmenu-run
set $dmenu $HOME/.local/bin/wmenu_desktop_entries.sh
set $calc kcalc
set $screenshot slurp | grim -g - - | swappy -f -
set $lock swaylock -f -c 000000 -i $wallpaper
set $clipboard cliphist list | wmenu | cliphist decode | wl-copy

# https://wiki.archlinux.org/title/Sway#Screencast_/_WebRTC_not_working
# Launch dbus
exec dbus-update-activation-environment \
    DISPLAY \
    I3SOCK \
    SWAYSOCK \
    WAYLAND_DISPLAY \
    XDG_CURRENT_DESKTOP=sway

# Autostart .desktop files
exec dex --autostart --environment sway

# Notification daemon
exec mako

# Autotiling
exec autotiling-rs

# Enable clipboard
exec wl-paste --watch cliphist store

exec swayidle -w \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         timeout 1800 "$lock" \
         before-sleep "$lock"

input "type:keyboard" {
    xkb_layout "es"
}

input type:touchpad {
    accel_profile "flat"
    pointer_accel 1
    click_method "clickfinger"
    tap enabled
    natural_scroll enabled
    drag enabled
    drag_lock enabled
}

input type:pointer {
    accel_profile "flat"
    pointer_accel 1
}

focus_follows_mouse no

include "style"
include "keybinds"
include "display"
include "apps"

